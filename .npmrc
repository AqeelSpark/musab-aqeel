# Project npm configuration.
#
# `package-lock=true`    — always maintain a lockfile (default, but explicit).
# `save-exact=false`     — keep `^` ranges in package.json; the lockfile
#                          already pins the exact resolution.
# `fund=false`           — suppress funding banners after installs.
# `audit=false`          — don't force an audit network call on every install;
#                          CI runs audits explicitly when needed.
# `engine-strict=true`   — hard-fail on Node version mismatch so drift caused
#                          by an unexpected Node can't slip in.
# `legacy-peer-deps=false` — explicit default. Keeps npm's modern
#                          peer-resolution path active, which is what the
#                          committed lockfile was generated with.

package-lock=true
save-exact=false
fund=false
audit=false
engine-strict=true
legacy-peer-deps=false
