# Project package manager configuration (pnpm).
#
# The lockfile (`pnpm-lock.yaml`) pins exact resolution; ranges in package.json
# stay as declared in dependencies.
# `fund=false`           — suppress funding banners after installs.
# `audit=false`          — don't force an audit network call on every install;
#                          CI runs audits explicitly when needed.
# `engine-strict=true`   — hard-fail on Node version mismatch so drift caused
#                          by an unexpected Node can't slip in.

fund=false
audit=false
engine-strict=true
